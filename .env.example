# ══════════════════════════════════════════════════════════════════════════════
# AI Due Diligence Copilot — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Ollama (local LLM — no API key needed) ───────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT=300

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=ddcopilot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ddcopilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Qdrant (self-hosted) ─────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=due_diligence_chunks

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO (self-hosted S3) ───────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=dd-documents
MINIO_SECURE=false

# ── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=200
BACKEND_CORS_ORIGINS=http://localhost:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
