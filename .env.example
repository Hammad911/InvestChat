# ══════════════════════════════════════════════════════════════════════════════
# AI Due Diligence Copilot — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Gemini API ─────────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Fast model for chat streaming
GEMINI_LLM_MODEL=gemini-2.5-flash
# Pro model for deep analysis (risks, growth, financials, summary)
# In production, set to: gemini-2.5-pro
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
# Embedding model — 768 dims (must match EMBED_DIM in embedder.py)
GEMINI_EMBED_MODEL=gemini-embedding-001
# Hard timeout on Gemini API calls (seconds). Returns 504 on expiry.
GEMINI_REQUEST_TIMEOUT=60

# ── Retrieval ────────────────────────────────────────────────────────────────
# Options: "hybrid" (recommended) | "dense" | "sparse"
RETRIEVAL_MODE=hybrid

# ── Semantic Cache ────────────────────────────────────────────────────────────
# Cosine similarity threshold for returning a cached response (0.0–1.0)
SEMANTIC_CACHE_THRESHOLD=0.90
# Redis DB index for the cache (use a different DB than Celery's broker)
SEMANTIC_CACHE_REDIS_DB=1

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max analysis/chat requests per user per minute
RATE_LIMIT_PER_MINUTE=20

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=ddcopilot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ddcopilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional: override with a full URL (e.g. Neon, Supabase)
# DATABASE_URL=postgresql://user:password@host:port/db?sslmode=require

# ── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=due_diligence_chunks
# Optional: Qdrant Cloud
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Optional: Upstash (TLS)
# REDIS_URL=rediss://default:token@host:port

# ── MinIO (S3-compatible object storage) ────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=forinvest
MINIO_SECURE=false
# Optional: Cloudflare R2 or AWS S3
# MINIO_ENDPOINT=your-account.r2.cloudflarestorage.com
# MINIO_SECURE=true

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=200
BACKEND_CORS_ORIGINS=http://localhost:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Observability ─────────────────────────────────────────────────────────────
# Optional: Sentry DSN for error tracking
# SENTRY_DSN=https://your-key@sentry.io/your-project

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
